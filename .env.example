# ─── AI Provider ──────────────────────────────────────────────────────────────
# Set ACTIVE_AI_PROVIDER to "openai", "gemini", or "groq"
ACTIVE_AI_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/esa_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / Security ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Vector Store ─────────────────────────────────────────────────────────────
# Set VECTOR_STORE to "faiss", "pinecone", or "pgvector"
VECTOR_STORE=faiss

PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=esa-bc-docs

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
